# =============================================================================
# Nord Meshnet Remote Desktop -- Local Environment
# =============================================================================

# Control plane bind address. Use a Meshnet-reachable IP or hostname in the app.
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8789
CONTROL_PLANE_PUBLIC_BASE_URL=http://127.0.0.1:8789

# Local persistence and logging.
CONTROL_PLANE_STATE_FILE=./services/control-plane/state/control-plane.json
# Default log target points at the repo-level data dir so Grafana Alloy can tail it.
CONTROL_PLANE_LOG_FILE=../../data/nord-meshnet-logs/control-plane.log

# Session security and UX.
SESSION_HMAC_SECRET=change-me-before-you-share-this-service
PAIRING_CODE_TTL_SECONDS=300
SESSION_REQUEST_TTL_SECONDS=120
SESSION_MAX_FILE_BYTES=10485760

# Optional Vault integration for mirrored session audit secrets / notifications.
VAULT_ADDR=
VAULT_TOKEN=
VAULT_SESSION_AUDIT_PATH=secret/nord-meshnet-remote-desktop/audit

# Optional n8n webhook for approval notifications or audit fan-out.
N8N_AUDIT_WEBHOOK_URL=
