{
  "dashboard": {
    "id": null,
    "uid": "openclaw-agent",
    "title": "OpenClaw Agent Activity",
    "description": "Tool calls, LLM usage/cost, session lifecycle, message throughput, failed tools",
    "tags": [
      "openclaw",
      "ai-agent",
      "auto-provisioned"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "title": "Tool Calls Over Time",
        "type": "timeseries",
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "count_over_time({service=\"openclaw\"} |= \"tool end\" [$__interval])",
            "refId": "A",
            "legendFormat": "Tool Calls"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "title": "Tool Calls by Tool",
        "type": "timeseries",
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "sum by (tool) (count_over_time({service=\"openclaw\"} |= \"tool end\" | regexp \"tool=(?P<tool>\\\\w+)\" [$__interval]))",
            "refId": "A",
            "legendFormat": "{{tool}}"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "title": "Agent Sessions",
        "type": "stat",
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "count_over_time({service=\"openclaw\"} |= \"run registered\" [24h])",
            "refId": "A",
            "legendFormat": "Sessions (24h)"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "title": "Agent Run Duration",
        "type": "stat",
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "avg_over_time({service=\"openclaw\"} |= \"run done\" | regexp \"durationMs=(?P<duration>\\\\d+)\" | unwrap duration [$__range])",
            "refId": "A",
            "legendFormat": "Avg Duration (ms)"
          }
        ],
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "title": "Warnings & Errors",
        "type": "timeseries",
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "count_over_time({service=\"openclaw\"} | json | _meta_logLevelName=\"WARN\" [$__interval])",
            "refId": "A",
            "legendFormat": "Warnings"
          },
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "count_over_time({service=\"openclaw\"} | json | _meta_logLevelName=\"ERROR\" [$__interval])",
            "refId": "B",
            "legendFormat": "Errors"
          }
        ],
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "title": "OpenClaw Log Stream",
        "type": "logs",
        "datasource": {
          "type": "loki",
          "uid": "grafanacloud-logs"
        },
        "targets": [
          {
            "datasource": {
              "type": "loki",
              "uid": "grafanacloud-logs"
            },
            "expr": "{service=\"openclaw\"}",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "sortOrder": "Descending"
        },
        "gridPos": {
          "h": 10,
          "w": 24,
          "x": 0,
          "y": 16
        }
      }
    ]
  },
  "overwrite": true,
  "folderId": 0
}
