{
  "dashboard": {
    "id": null,
    "uid": "parallels-host",
    "title": "Parallels Desktop / VM Host",
    "description": "VM CPU/memory/disk/network, VM state, macOS host metrics",
    "tags": [
      "parallels",
      "vm",
      "host",
      "auto-provisioned"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "n8n Up",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "up{job=\"n8n\"} or vector(0)",
            "legendFormat": "State",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "1": {
                    "text": "Running",
                    "color": "green"
                  }
                }
              },
              {
                "type": "value",
                "options": {
                  "0": {
                    "text": "Stopped",
                    "color": "red"
                  }
                }
              }
            ]
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        }
      },
      {
        "id": 2,
        "title": "Host CPU Usage (%)",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "CPU Load",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 90
                }
              ]
            }
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        }
      },
      {
        "id": 3,
        "title": "Host Memory Usage (%)",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "legendFormat": "Memory Load",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 90
                }
              ]
            }
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        }
      },
      {
        "id": 4,
        "title": "Disk I/O",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(node_disk_read_bytes_total[5m])",
            "legendFormat": "Read",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          },
          {
            "expr": "rate(node_disk_written_bytes_total[5m])",
            "legendFormat": "Write",
            "refId": "B",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        }
      },
      {
        "id": 5,
        "title": "Host CPU (%)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "legendFormat": "Host CPU %",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 85
                }
              ]
            }
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        }
      },
      {
        "id": 6,
        "title": "Host Memory (%)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
            "legendFormat": "Host Memory %",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "grafanacloud-prom"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 70
                },
                {
                  "color": "red",
                  "value": 85
                }
              ]
            }
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        }
      }
    ]
  },
  "overwrite": true,
  "folderId": 0
}
