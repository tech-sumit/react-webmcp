###############################################################################
# AI-Native n8n Automation System -- Environment Configuration
#
# Copy this file to .env and fill in the REQUIRED values.
# Run `make generate-secrets` to auto-generate internal secrets.
# Optional values show their defaults -- only set to override.
###############################################################################

# =============================================================================
# Section 1: Parallels Desktop / VM
# =============================================================================

# REQUIRED -- Root password for prldevops REST API
PRLDEVOPS_ROOT_PASSWORD=

# Optional -- Parallels Desktop license key (for Terraform provider)
# PARALLELS_LICENSE=

# Optional -- VM configuration (defaults shown)
# VM_NAME=n8n-ai-worker
# VM_CPU_COUNT=4
# VM_MEMORY_MB=8192
# VM_DISK_SIZE_MB=65536
# VM_SSH_PORT=2222
# VM_USER=parallels
# VM_PASSWORD=parallels
# HOST_IP=10.211.55.2

# =============================================================================
# Section 2: n8n Workflow Engine
# =============================================================================

# REQUIRED -- Encryption key for stored credentials (auto-generated by `make generate-secrets`)
N8N_ENCRYPTION_KEY=

# REQUIRED -- Public webhook URL (e.g., https://n8n.yourdomain.com/)
N8N_WEBHOOK_URL=

# REQUIRED -- n8n REST API key (JWT, created via n8n Settings > API or scripts/n8n-ctl.sh)
# In n8n v2+, API keys are JWTs with audience=public-api (not plain hex strings)
N8N_API_KEY=

# Optional -- n8n configuration (defaults shown)
# N8N_HOST=0.0.0.0
# N8N_PORT=5678
# N8N_PROTOCOL=https
# N8N_LOG_LEVEL=info
# N8N_LOG_FORMAT=json
# N8N_METRICS=true
# N8N_EXECUTIONS_MODE=queue

# =============================================================================
# Section 3: PostgreSQL
# =============================================================================

# REQUIRED -- Database password (auto-generated by `make generate-secrets`)
POSTGRES_PASSWORD=

# Optional -- PostgreSQL configuration (defaults shown)
# POSTGRES_DB=n8n
# POSTGRES_USER=n8n
# POSTGRES_PORT=5432

# =============================================================================
# Section 4: HashiCorp Vault
# =============================================================================

# REQUIRED -- Root token for Vault (auto-generated by `make generate-secrets`)
VAULT_ROOT_TOKEN=

# Optional -- Vault configuration (defaults shown)
# VAULT_PORT=8200
# VAULT_STORAGE_TYPE=file
# VAULT_LOG_LEVEL=info

# =============================================================================
# Section 5: Redis
# =============================================================================

# Optional -- Redis password (auto-generated by `make generate-secrets`, empty = no auth)
REDIS_PASSWORD=

# Optional -- Redis configuration (defaults shown)
# REDIS_PORT=6379
# REDIS_MAXMEMORY=256mb

# =============================================================================
# Section 6: Cloudflare Tunnel
# =============================================================================

# Auto-generated by Terraform. Or set manually if using a dashboard-managed tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# REQUIRED -- Your domain (e.g., yourdomain.com)
CLOUDFLARE_DOMAIN=

# REQUIRED -- API token with DNS + Tunnel permissions
CLOUDFLARE_API_TOKEN=

# REQUIRED -- Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=

# Subdomain for OpenClaw gateway (default: bot-0 → bot-0.yourdomain.com)
# Note: avoid underscores -- browsers reject them in HTTP hostnames
OPENCLAW_SUBDOMAIN=bot-0

# Email for Cloudflare Access policy on OpenClaw gateway.
# When set, Access Application is created: only this email is allowed through.
# Leave empty to skip Access (origin still protected by OpenClaw's own token auth).
CLOUDFLARE_ACCESS_EMAIL=

# =============================================================================
# Section 7: Grafana Cloud (Observability)
# =============================================================================

# REQUIRED -- Mimir remote_write endpoint
GRAFANA_CLOUD_PROMETHEUS_URL=

# REQUIRED -- Loki push endpoint
GRAFANA_CLOUD_LOKI_URL=

# REQUIRED -- Grafana Cloud Prometheus instance ID (numeric)
GRAFANA_CLOUD_USER=

# REQUIRED -- Grafana Cloud Loki instance ID (numeric, different from Prometheus)
GRAFANA_CLOUD_LOKI_USER=

# REQUIRED -- API key for metrics + logs push
GRAFANA_CLOUD_API_KEY=

# REQUIRED -- Dashboard URL (e.g., https://yourstack.grafana.net)
GRAFANA_CLOUD_STACK_URL=

# REQUIRED -- Service account token (Editor role) for dashboard/alert provisioning
GRAFANA_CLOUD_ADMIN_TOKEN=

# Optional -- Alerting API base URL (derived from STACK_URL if not set)
# GRAFANA_CLOUD_ALERTING_URL=

# Optional -- Metrics scrape frequency
# ALLOY_SCRAPE_INTERVAL=15s

# =============================================================================
# Section 8: AWS (Terraform -- S3 module, optional)
# =============================================================================

# Optional -- Only needed if using the S3 module
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_PREFIX=n8n-assets

# =============================================================================
# Section 9: GitHub (Terraform -- GitHub module, optional)
# =============================================================================

# Optional -- Only needed if using the GitHub module
# GITHUB_TOKEN=
# GITHUB_OWNER=

# =============================================================================
# Section 10: OpenClaw (AI Agent)
# =============================================================================

# REQUIRED -- LLM provider API key
OPENCLAW_API_KEY=

# Optional -- OpenClaw configuration (defaults shown)
# OPENCLAW_MODEL_PROVIDER=anthropic
# OPENCLAW_MODEL=claude-sonnet-4-20250514
# OPENCLAW_LOG_LEVEL=info
# OPENCLAW_TELEMETRY_ENABLED=true
# OPENCLAW_PORT=18789

# Optional -- Telegram bot token (from @BotFather). Enables Telegram channel in OpenClaw.
# TELEGRAM_BOT_TOKEN=

# =============================================================================
# Section 11: NordVPN (for Instagram media downloader VPN proxy)
# =============================================================================

# REQUIRED if using the Instagram downloader workflow with VPN proxy
# Obtain service credentials (NOT your email/password) from:
# https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/service-credentials/
NORDVPN_USER=
NORDVPN_PASSWORD=

# Optional -- VPN server location (default: India)
# NORDVPN_COUNTRY=India

# =============================================================================
# Section 12: System / General
# =============================================================================

# Optional -- General configuration (defaults shown)
# PROJECT_NAME=n8n-ai
# SHARED_DIR=./shared
# BACKUP_DIR=./backups
# TZ=UTC
# COMPOSE_PROFILES=

# =============================================================================
# Section 13: Website Factory (optional — AI website generation pipeline)
# =============================================================================

# Google Places API key (for business data enrichment)
# GOOGLE_PLACES_API_KEY=

# SendGrid API key (for client email notifications)
# SENDGRID_API_KEY=

# GitHub token and org for generated repos (reuse Section 9 values or set separately)
# GITHUB_TOKEN=
# GITHUB_OWNER=tech-sumit
