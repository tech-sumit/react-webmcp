# Pages CMS - Copy to .env and fill in your values
# See: https://github.com/pages-cms/pages-cms#create-a-github-app

# Public URL (via Cloudflare tunnel from the main n8n stack)
BASE_URL=https://cms.panditai.org

# Generate with: openssl rand -base64 32
CRYPTO_KEY=your-crypto-key-here

# From your GitHub App (https://github.com/settings/apps)
GITHUB_APP_ID=your-app-id
GITHUB_APP_NAME=your-app-slug
GITHUB_APP_CLIENT_ID=your-client-id
GITHUB_APP_CLIENT_SECRET=your-client-secret
GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# GitHub App private key (from PEM download) - use actual newlines or \n
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Resend (https://resend.com) - for auth emails
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here
